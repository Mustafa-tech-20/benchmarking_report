# Google Cloud Configuration
# =========================
# Set to TRUE to use Vertex AI (recommended for production)
# Set to FALSE to use Google AI Studio API directly
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# Google Cloud Project Settings
# Get these from: https://console.cloud.google.com/
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Google API Key (required if GOOGLE_GENAI_USE_VERTEXAI=FALSE)
# Get from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key

# Google Custom Search API
# =========================
# Create a Programmable Search Engine at: https://programmablesearchengine.google.com/
# Enable "Search the entire web" for general search
SEARCH_ENGINE_ID=your-search-engine-id
COMPANY_SEARCH_ID=your-company-search-id

# Google Cloud Storage
# ====================
# Create a bucket at: https://console.cloud.google.com/storage
GCS_BUCKET_NAME=your-bucket-name

# RAG Corpus 
# =============================
# Create at: https://console.cloud.google.com/vertexai/ragcorpus
RAG_CORPUS_ID=your-rag-corpus-id

# Service Account Credentials
# ===========================
# Download from: https://console.cloud.google.com/iam-admin/serviceaccounts
# 1. Create a service account
# 2. Grant roles: Vertex AI User, Storage Object Admin, Discovery Engine Editor
# 3. Create and download JSON key
# 4. Place the file in project root as service.json
GOOGLE_APPLICATION_CREDENTIALS=./service.json
